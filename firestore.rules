rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Anyone can browse the catalog; only admins (see /admins/{uid}) can change it.
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null &&
                      exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Anyone signed in (or anonymous, if you enable that) can place an order,
    // but only admins can read the order list or edit/delete orders.
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null &&
                      exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // The admin allow-list itself: nobody can write to it from the client.
    // Add admins manually from the Firebase console (Firestore → admins → add doc
    // with the document ID set to that user's Auth UID).
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
  }
}
